#!/usr/bin/expect -f
set timeout 300
set user [lindex $argv 0]
set pass [lindex $argv 1]
set local [lindex $argv 2]
set remote [lindex $argv 3]
set host "134.209.172.50"

spawn scp -o StrictHostKeyChecking=no -r $local ${user}@${host}:$remote
expect {
    -re "(?i)password:" {
        send "$pass\r"
        exp_continue
    }
    eof
}
catch wait result
exit [lindex $result 3]
