#!/usr/bin/expect -f
set timeout 120
set user [lindex $argv 0]
set pass [lindex $argv 1]
set cmd [lindex $argv 2]
set host "134.209.172.50"

spawn ssh -o StrictHostKeyChecking=no -o ConnectTimeout=25 ${user}@${host} $cmd
expect {
    -re "(?i)password:" {
        send "$pass\r"
        exp_continue
    }
    eof
}
catch wait result
exit [lindex $result 3]
