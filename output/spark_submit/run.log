## Command (run on cluster)

```bash
source /etc/profile.d/hadoop.sh
export SPARK_HOME=/opt/spark
export PATH=$SPARK_HOME/bin:$PATH
PY4J=/opt/spark/python/lib/py4j-0.10.9.7-src.zip
export PYTHONPATH=$SPARK_HOME/python:$PY4J:$HOME/se446-project-group-5
cd ~/se446-project-group-5

spark-submit \
  --master yarn \
  --deploy-mode cluster \
  --driver-memory 512m \
  --num-executors 1 \
  --executor-memory 1g \
  --executor-cores 1 \
  --conf spark.driver.maxResultSize=128m \
  --conf spark.yarn.appMasterEnv.PYSPARK_PYTHON=python3 \
  --conf spark.executorEnv.PYSPARK_PYTHON=python3 \
  m2_spark_ml.py --hdfs-path hdfs:///data/chicago_crimes.csv --sample-fraction 0.05
```

